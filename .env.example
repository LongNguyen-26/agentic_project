# DUT_Trust environment example
# Copy this file to .env and update required secrets before running.
# Linux/macOS: cp .env.example .env
# Windows (cmd): copy .env.example .env

# Required
COMPETITION_BASE_URL="<your_competition_base_url>"
API_KEY="<your_competition_api_key>"
OPENAI_API_KEY="<your_openai_api_key>"

# OpenAI models
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
MODEL_NAME="gpt-4o"
REASONING_MODEL="o3-mini"

# Storage / logging
STORAGE_ROOT="storage"
LOG_LEVEL="INFO"
LOG_FILE="storage/agent.log"
LOG_MAX_BYTES="10485760"
LOG_BACKUP_COUNT="5"

# HTTP resilience
HTTP_TIMEOUT_SECONDS="40"
HTTP_MAX_RETRIES="4"
HTTP_BACKOFF_SECONDS="1.0"

# LLM resilience
LLM_MAX_RETRIES="4"
LLM_RETRY_BASE_DELAY="1.0"
LLM_RETRY_JITTER="0.2"
LLM_RETRY_MAX_OUTPUT_TOKENS="36000"
LLM_RETRY_TOKEN_GROWTH_FACTOR="2.0"

# Token budgets
TASK_CLASSIFICATION_MAX_OUTPUT_TOKENS="256"
TASK_CLASSIFICATION_RETRY_MAX_OUTPUT_TOKENS="1024"
PLANNING_HINTS_MAX_OUTPUT_TOKENS="896"
PLANNING_HINTS_RETRY_MAX_OUTPUT_TOKENS="2400"
CLASSIFICATION_MAX_TOKENS="64"
LLM_MAX_OUTPUT_TOKENS="1800"
VERIFICATION_MAX_OUTPUT_TOKENS="1600"
QA_ACTION_MAX_OUTPUT_TOKENS="1800"
QA_VERIFICATION_MAX_OUTPUT_TOKENS="1600"
QA_ACTION_RETRY_MAX_OUTPUT_TOKENS="7200"
QA_VERIFICATION_RETRY_MAX_OUTPUT_TOKENS="5600"
SORT_ACTION_MAX_OUTPUT_TOKENS="16000"
SORT_VERIFICATION_MAX_OUTPUT_TOKENS="10000"
SORT_ACTION_RETRY_MAX_OUTPUT_TOKENS="28000"
SORT_VERIFICATION_RETRY_MAX_OUTPUT_TOKENS="16000"

# File summary controls
FILE_SUMMARY_SOURCE_MAX_CHARS="80000"
FILE_SUMMARY_MAX_OUTPUT_TOKENS="4096"
FILE_SUMMARY_RETRY_MAX_OUTPUT_TOKENS="8192"
RAG_SUMMARY_MAX_CHARS="280"

# Parser controls
PDF_OCR_MAX_PAGES="30"

# QA retrieval / reranking
QA_RAG_DOC_THRESHOLD="5"
RAG_CHUNK_SIZE="1000"
RAG_CHUNK_OVERLAP="100"
RAG_TOP_K="8"
RAG_RERANK_ENABLED="true"
RAG_RERANK_MODEL="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
RAG_RERANK_DEVICE="cpu"
RAG_RERANK_PRE_TOP_K="20"
RAG_RERANK_BATCH_SIZE="16"

# Evidence / verification gates
EVIDENCE_MAX_ITEMS="5"
EVIDENCE_MAX_CHARS_PER_ITEM="1200"
MAX_RETRIES="3"
VERIFIER_MIN_CONFIDENCE="0.60"
QA_GROUNDING_ENFORCED="true"
QA_GROUNDING_MIN_EVIDENCE_MARKERS="1"
QA_ANSWER_LOG_MAX_CHARS="12000"
